@baseUrl = http://localhost:5021

### Seed demo data
POST {{baseUrl}}/api/seed
Content-Type: application/json

### Check: customer-001 can ViewBalance on account-100 (ALLOWED)
POST {{baseUrl}}/api/entitlements/check
Content-Type: application/json

{
  "subjectId": "customer-001",
  "permissionName": "ViewBalance",
  "resourceId": "account-100"
}

### Check: customer-001 can InitiateTransfer on account-100 (ALLOWED)
POST {{baseUrl}}/api/entitlements/check
Content-Type: application/json

{
  "subjectId": "customer-001",
  "permissionName": "InitiateTransfer",
  "resourceId": "account-100"
}

### Check: customer-002 tries ViewBalance on account-200 (Allowed)
POST {{baseUrl}}/api/entitlements/check
Content-Type: application/json

{
  "subjectId": "customer-002",
  "permissionName": "ViewBalance",
  "resourceId": "account-200"
}

### Check: customer-002 tries InitiateTransfer on account-200 (DENIED - only has ViewBalance)
POST {{baseUrl}}/api/entitlements/check
Content-Type: application/json

{
  "subjectId": "customer-002",
  "permissionName": "InitiateTransfer",
  "resourceId": "account-200"
}

### Check: customer-001 tries ApprovePayment on account-100 (DENIED - no role grants this permission)
POST {{baseUrl}}/api/entitlements/check
Content-Type: application/json

{
  "subjectId": "customer-001",
  "permissionName": "ApprovePayment",
  "resourceId": "account-100"
}

### Check: operator-001 tries ViewUserProfile on account-200 (Allowed)
POST {{baseUrl}}/api/entitlements/check
Content-Type: application/json

{
  "subjectId": "operator-001",
  "permissionName": "ViewUserProfile",
  "resourceId": "account-200"
}

### Check: operator-001 tries ViewBalance on account-200 (DENIED)
POST {{baseUrl}}/api/entitlements/check
Content-Type: application/json

{
  "subjectId": "operator-001",
  "permissionName": "ViewBalance",
  "resourceId": "account-200"
}

### Check: unknown subject (DENIED)
POST {{baseUrl}}/api/entitlements/check
Content-Type: application/json

{
  "subjectId": "unknown-999",
  "permissionName": "ViewBalance",
  "resourceId": "account-100"
}
